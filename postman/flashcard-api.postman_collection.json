{
  "info": {
    "name": "Flashcard API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "let token = pm.environment.get('token');",
          "if (token) {",
          "  pm.request.headers.add({ key: 'Authorization', value: 'Bearer ' + token });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Register",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.environment.set('username', 'pm-' + Date.now());",
              "pm.environment.set('password', 'pm-pass');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('latency < 500ms', function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(500);",
              "});",
              "",
              "let schema = {",
              "  type: 'object',",
              "  required: ['data'],",
              "  properties: {",
              "    data: {",
              "      type: 'object',",
              "      required: ['id', 'username'],",
              "      properties: {",
              "        id: { type: 'number' },",
              "        username: { type: 'string' }",
              "      }",
              "    }",
              "  }",
              "};",
              "pm.test('schema valid', function () {",
              "  pm.expect(tv4.validate(pm.response.json(), schema)).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": "{{base_url}}/api/auth/register"
      }
    },
    {
      "name": "Login",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.environment.get('username')) {",
              "  pm.environment.set('username', 'pm-' + Date.now());",
              "  pm.environment.set('password', 'pm-pass');",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('latency < 500ms', function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(500);",
              "});",
              "",
              "let schema = {",
              "  type: 'object',",
              "  required: ['data'],",
              "  properties: {",
              "    data: {",
              "      type: 'object',",
              "      required: ['token'],",
              "      properties: {",
              "        token: { type: 'string' }",
              "      }",
              "    }",
              "  }",
              "};",
              "pm.test('schema valid', function () {",
              "  pm.expect(tv4.validate(pm.response.json(), schema)).to.be.true;",
              "});",
              "",
              "pm.environment.set('token', pm.response.json().data.token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": "{{base_url}}/api/auth/login"
      }
    },
    {
      "name": "Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('latency < 200ms', function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(200);",
              "});",
              "",
              "let schema = {",
              "  type: 'object',",
              "  required: ['status'],",
              "  properties: {",
              "    status: { type: 'string' }",
              "  }",
              "};",
              "pm.test('schema valid', function () {",
              "  pm.expect(tv4.validate(pm.response.json(), schema)).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{base_url}}/health"
      }
    },
    {
      "name": "Create Deck",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.environment.set('deck_name', 'Postman Deck ' + Date.now());"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('latency < 500ms', function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(500);",
              "});",
              "",
              "let schema = {",
              "  type: 'object',",
              "  required: ['data'],",
              "  properties: {",
              "    data: {",
              "      type: 'object',",
              "      required: ['id', 'name', 'flashcards'],",
              "      properties: {",
              "        id: { type: 'number' },",
              "        name: { type: 'string' },",
              "        description: { type: ['string', 'null'] },",
              "        flashcards: { type: 'array' },",
              "        created_at: { type: 'string' }",
              "      }",
              "    }",
              "  }",
              "};",
              "pm.test('schema valid', function () {",
              "  pm.expect(tv4.validate(pm.response.json(), schema)).to.be.true;",
              "});",
              "",
              "pm.test('deck name matches generated value', function () {",
              "  pm.expect(pm.response.json().data.name).to.eql(pm.environment.get('deck_name'));",
              "});",
              "",
              "pm.environment.set('deck_id', pm.response.json().data.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{deck_name}}\",\n  \"description\": \"Postman ile olusturulan deck\"\n}"
        },
        "url": "{{base_url}}/api/decks"
      }
    },
    {
      "name": "List Decks",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('latency < 300ms', function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(300);",
              "});",
              "",
              "let schema = {",
              "  type: 'object',",
              "  required: ['data'],",
              "  properties: {",
              "    data: { type: 'array' }",
              "  }",
              "};",
              "pm.test('schema valid', function () {",
              "  pm.expect(tv4.validate(pm.response.json(), schema)).to.be.true;",
              "});",
              "",
              "pm.test('created deck appears in deck list', function () {",
              "  let deckName = pm.environment.get('deck_name');",
              "  let names = pm.response.json().data.map(function (deck) { return deck.name; });",
              "  pm.expect(names).to.include(deckName);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{base_url}}/api/decks"
      }
    },
    {
      "name": "Get Deck",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('latency < 300ms', function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(300);",
              "});",
              "",
              "let schema = {",
              "  type: 'object',",
              "  required: ['data'],",
              "  properties: {",
              "    data: {",
              "      type: 'object',",
              "      required: ['id', 'name', 'flashcards'],",
              "      properties: {",
              "        id: { type: 'number' },",
              "        name: { type: 'string' },",
              "        description: { type: ['string', 'null'] },",
              "        flashcards: { type: 'array' },",
              "        created_at: { type: 'string' }",
              "      }",
              "    }",
              "  }",
              "};",
              "pm.test('schema valid', function () {",
              "  pm.expect(tv4.validate(pm.response.json(), schema)).to.be.true;",
              "});",
              "",
              "pm.test('deck detail matches stored deck id', function () {",
              "  pm.expect(pm.response.json().data.id).to.eql(Number(pm.environment.get('deck_id')));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{base_url}}/api/decks/{{deck_id}}"
      }
    },
    {
      "name": "Create Flashcard",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.environment.set('flashcard_front', 'Flask nedir? ' + Date.now());",
              "pm.environment.set('flashcard_back', 'Python web framework');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('latency < 500ms', function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(500);",
              "});",
              "",
              "let schema = {",
              "  type: 'object',",
              "  required: ['data'],",
              "  properties: {",
              "    data: {",
              "      type: 'object',",
              "      required: ['id', 'front', 'back'],",
              "      properties: {",
              "        id: { type: 'number' },",
              "        front: { type: 'string' },",
              "        back: { type: 'string' },",
              "        difficulty: { type: 'string' },",
              "        review_count: { type: 'number' },",
              "        next_review_at: { type: ['string', 'null'] },",
              "        interval_days: { type: 'number' }",
              "      }",
              "    }",
              "  }",
              "};",
              "pm.test('schema valid', function () {",
              "  pm.expect(tv4.validate(pm.response.json(), schema)).to.be.true;",
              "});",
              "",
              "pm.test('flashcard starts as new', function () {",
              "  let data = pm.response.json().data;",
              "  pm.expect(data.front).to.eql(pm.environment.get('flashcard_front'));",
              "  pm.expect(data.back).to.eql(pm.environment.get('flashcard_back'));",
              "  pm.expect(data.difficulty).to.eql('new');",
              "  pm.expect(data.review_count).to.eql(0);",
              "});",
              "",
              "pm.environment.set('flashcard_id', pm.response.json().data.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"front\": \"{{flashcard_front}}\",\n  \"back\": \"{{flashcard_back}}\"\n}"
        },
        "url": "{{base_url}}/api/decks/{{deck_id}}/flashcards"
      }
    },
    {
      "name": "Review Flashcard",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('latency < 500ms', function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(500);",
              "});",
              "",
              "let schema = {",
              "  type: 'object',",
              "  required: ['data'],",
              "  properties: {",
              "    data: {",
              "      type: 'object',",
              "      required: ['id', 'difficulty', 'next_review_at', 'interval_days'],",
              "      properties: {",
              "        id: { type: 'number' },",
              "        front: { type: 'string' },",
              "        back: { type: 'string' },",
              "        difficulty: { type: 'string' },",
              "        review_count: { type: 'number' },",
              "        next_review_at: { type: ['string', 'null'] },",
              "        interval_days: { type: 'number' }",
              "      }",
              "    }",
              "  }",
              "};",
              "pm.test('schema valid', function () {",
              "  pm.expect(tv4.validate(pm.response.json(), schema)).to.be.true;",
              "});",
              "",
              "pm.test('review updates flashcard state', function () {",
              "  let data = pm.response.json().data;",
              "  pm.expect(data.difficulty).to.eql('good');",
              "  pm.expect(data.review_count).to.eql(1);",
              "  pm.expect(data.next_review_at).to.not.eql(null);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"difficulty\": \"good\"\n}"
        },
        "url": "{{base_url}}/api/flashcards/{{flashcard_id}}/review"
      }
    },
    {
      "name": "Delete Flashcard",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('latency < 500ms', function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(500);",
              "});",
              "",
              "let schema = {",
              "  type: 'object',",
              "  required: ['data'],",
              "  properties: {",
              "    data: {",
              "      type: 'object',",
              "      required: ['deleted'],",
              "      properties: {",
              "        deleted: { type: 'boolean' }",
              "      }",
              "    }",
              "  }",
              "};",
              "pm.test('schema valid', function () {",
              "  pm.expect(tv4.validate(pm.response.json(), schema)).to.be.true;",
              "});",
              "",
              "pm.test('flashcard marked deleted', function () {",
              "  pm.expect(pm.response.json().data.deleted).to.eql(true);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "url": "{{base_url}}/api/flashcards/{{flashcard_id}}"
      }
    }
  ]
}
